{
    "version": 2,
    "builds": [
        {
            "src": "server/api/src/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "client/package.json",
            "use": "@vercel/static-build"
        }
    ],
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "server/api/src/index.js"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "client/$1"
        },
        {
            "source": "/(.*)",
            "destination": "client/index.html"
        }
    ]
}
